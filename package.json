{
    "name": "personal-brand-website",
    "version": "0.1.0",
    "description": "Personal brand website — Astro + Starlight",
    "type": "module",
    "license": "MIT",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "sync-spec": "node scripts/sync-spec.mjs",
        "fetch-refs": "node scripts/fetch-refs.mjs",
        "generate-markdown-map": "node scripts/generate-markdown-map.mjs",
        "generate-llms-txt": "node scripts/generate-llms-txt.mjs",
        "generate-robots-txt": "node scripts/generate-robots-txt.mjs",
        "inject-pagefind-meta": "node scripts/inject-pagefind-meta.mjs",
        "favicons": "node scripts/generate-favicons.mjs",
        "generate-og": "node scripts/generate-og.mjs",
        "dev": "npm run sync-spec && npm run generate-markdown-map && astro dev",
        "build": "npm run sync-spec && npm run fetch-refs && npm run generate-markdown-map && npm run generate-llms-txt && npm run generate-robots-txt && npm run inject-pagefind-meta && astro build",
        "preview": "astro preview"
    },
    "dependencies": {
        "@astrojs/rss": "^4.0.18",
        "@astrojs/starlight": "^0.38.2",
        "astro": "^6.4.6",
        "rehype-mermaid": "^3.0.0",
        "remark-gfm": "^4.0.1",
        "sharp": "^0.34.2"
    },
    "overrides": {
        "esbuild": "^0.28.1"
    },
    "devDependencies": {
        "playwright": "1.60.0"
    }
}
