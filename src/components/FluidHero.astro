---
// src/components/FluidHero.astro — bespoke landing-only "Aurora" hero.
//
// Memo 017 (F4/F5, T006/T007/T008): the aurora is a FULL-BLEED `position: fixed;
// inset: 0` layer behind the entire landing — this fixes the old "shield"/framed-
// card look (T007), which came from the aurora being clipped inside a bordered,
// negative-margin section. Palette is now cool + restrained (low-saturation cyan,
// F4); softness comes from a strong `filter: blur()` (F5) over the near-black
// canvas with `mix-blend-mode: screen`; drift is very slow and transform-only.
// Zero deps, no canvas, no WebGL. The 3-tier auto-select stays: Full (cursor glow)
// / Reduced (slow ambient drift) / Static (pure CSS). The rAF loop self-stops at
// rest / hidden tab, so it costs ~0% CPU idle. The component only renders on the
// landing, so the fixed layer exists there only.
const { title = 'a6b8', tagline = '' } = Astro.props
---
<div class="fh-bg" data-fluid-hero aria-hidden="true">
    <div class="fh-aurora"></div>
    <div class="fh-blob fh-blob--lead"></div>
    <div class="fh-blob fh-blob--trail"></div>
</div>

<section class="fluid-hero">
    <div class="fh-content">
        <h1 class="fh-title">{title}</h1>
        {tagline && <p class="fh-tagline">{tagline}</p>}
        <div class="fh-actions"><slot /></div>
    </div>
</section>

<style>
    /* FULL-BLEED fixed layer behind the whole landing (T007 fix). It sits above the
     * html canvas gradient and below content — the Starlight panels are already
     * transparent (theme.css), so it shows through. No border, no radius, no
     * negative margins: full-bleed, not a framed "shield". */
    .fh-bg {
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        overflow: hidden;
        /* CSS vars the script writes (viewport px); default = centred-ish */
        --tx: 50vw; --ty: 40vh;
        --tx2: 50vw; --ty2: 40vh;
    }

    .fluid-hero {
        position: relative;
        min-height: clamp(24rem, 62vh, 40rem);
        display: grid;
        place-items: center;
    }

    .fh-content {
        position: relative;
        z-index: 1;
        text-align: center;
        padding: 2rem 1.5rem;
        max-width: 46rem;
        /* whisper of headline parallax written by the script (compositor-only) */
        transform: translate3d(var(--px, 0), var(--py, 0), 0);
    }
    .fh-title {
        font-size: clamp(2.5rem, 7vw, 4.75rem);
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: -0.03em;
        margin: 0;
        color: var(--text-primary, #f0f6fc);
        /* cool white -> soft cyan (T006), replaces the old white -> warm amber */
        background: linear-gradient(180deg, #ffffff 0%, #cfe8f0 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .fh-tagline {
        margin: 1.25rem auto 0;
        font-size: clamp(1rem, 2.2vw, 1.25rem);
        line-height: 1.6;
        color: var(--text-inactive, #8b949e);
        max-width: 34rem;
    }
    .fh-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 2rem;
    }

    /* STATIC COOL AURORA — always on, pure CSS. Soft light via big blur + screen
     * blend over the near-black canvas (F5). reduced-motion / weak-device baseline. */
    .fh-aurora {
        position: absolute;
        inset: -25%;
        background:
            radial-gradient(38% 50% at 28% 30%, hsl(193 45% 55% / 0.28), transparent 70%),
            radial-gradient(42% 48% at 74% 60%, hsl(205 42% 58% / 0.22), transparent 70%),
            radial-gradient(34% 44% at 52% 84%, hsl(184 38% 50% / 0.18), transparent 70%);
        filter: blur(90px) saturate(1.02);
        will-change: transform;
    }

    /* CURSOR BLOBS — soft light, transform-only, strong blur (F5). */
    .fh-blob {
        position: absolute;
        width: 46rem;
        height: 46rem;
        left: 0;
        top: 0;
        margin-left: -23rem;
        margin-top: -23rem;
        background: radial-gradient(closest-side, hsl(193 48% 60% / 0.30), transparent 70%);
        transform: translate3d(var(--tx), var(--ty), 0);
        filter: blur(60px);
        will-change: transform;
        mix-blend-mode: screen;
    }
    .fh-blob--trail {
        width: 32rem;
        height: 32rem;
        margin-left: -16rem;
        margin-top: -16rem;
        background: radial-gradient(closest-side, hsl(205 44% 56% / 0.24), transparent 70%);
        transform: translate3d(var(--tx2), var(--ty2), 0);
    }

    /* REDUCED tier: very slow ambient drift, compositor-only (transform, F5). */
    @media (prefers-reduced-motion: no-preference) {
        .fh-aurora { animation: fh-drift 18s ease-in-out infinite alternate; }
    }
    @keyframes fh-drift {
        to { transform: translate3d(2%, -2%, 0) scale(1.05); }
    }

    /* Static tier: never expose blob motion to reduced-motion users. */
    @media (prefers-reduced-motion: reduce) {
        .fh-blob { display: none; }
        .fh-aurora { animation: none; }
    }

    @media (max-width: 50rem) {
        .fluid-hero { min-height: clamp(20rem, 54vh, 30rem); }
        .fh-aurora { filter: blur(70px) saturate(1.02); }
    }
</style>

<script>
    // Self-gating: reproduces client:idle + client:visible without a framework
    // runtime. The fixed full-viewport layer tracks the cursor in VIEWPORT
    // coordinates (clientX/clientY), so blob offsets are plain viewport px.
    const boot = () => {
        const bg = document.querySelector( '[data-fluid-hero]' )
        if( !bg ) { return }

        const okMotion = matchMedia( '(prefers-reduced-motion: no-preference)' ).matches
        const fine = matchMedia( '(hover: hover) and (pointer: fine)' ).matches
        const cores = navigator.hardwareConcurrency ?? 4
        const memory = navigator.deviceMemory ?? 4
        const saveData = navigator.connection?.saveData === true
        const weak = cores <= 4 || memory < 4 || saveData

        // Reduced/Static tiers: leave the pure-CSS aurora as-is. No listeners, no loop.
        if( !okMotion || !fine || weak ) { return }

        const lead = bg.querySelector( '.fh-blob--lead' )
        const trail = bg.querySelector( '.fh-blob--trail' )
        const content = document.querySelector( '.fh-content' )

        let vw = window.innerWidth, vh = window.innerHeight
        window.addEventListener( 'resize', () => { vw = window.innerWidth; vh = window.innerHeight }, { passive: true } )

        let tx = vw / 2, ty = vh * 0.4
        let lx = tx, ly = ty
        let sx = tx, sy = ty
        let running = false, raf = 0, slowFrames = 0, lastT = 0

        const onMove = ( e ) => {
            tx = e.clientX
            ty = e.clientY
            if( !running ) { start() }
        }

        const frame = ( t ) => {
            const dt = t - lastT
            lastT = t
            lx += ( tx - lx ) * 0.12
            ly += ( ty - ly ) * 0.12
            sx += ( tx - sx ) * 0.06
            sy += ( ty - sy ) * 0.06
            lead.style.setProperty( '--tx', lx + 'px' )
            lead.style.setProperty( '--ty', ly + 'px' )
            trail.style.setProperty( '--tx2', sx + 'px' )
            trail.style.setProperty( '--ty2', sy + 'px' )

            // whisper of headline parallax (max ~10px), compositor-only
            if( content ) {
                const px = ( ( lx / vw ) - 0.5 ) * -16
                const py = ( ( ly / vh ) - 0.5 ) * -10
                content.style.setProperty( '--px', px.toFixed( 2 ) + 'px' )
                content.style.setProperty( '--py', py.toFixed( 2 ) + 'px' )
            }

            // watchdog: sustained slow frames => degrade to static and bail
            if( dt > 50 && ++slowFrames > 12 ) { return stop( true ) }
            else if( dt <= 50 ) { slowFrames = 0 }

            // rest-detection: settle => stop the loop, idle at 0% CPU
            const atRest = Math.hypot( tx - lx, ty - ly ) < 0.4 && Math.hypot( tx - sx, ty - sy ) < 0.4
            if( atRest ) { return stop( false ) }
            raf = requestAnimationFrame( frame )
        }

        const start = () => {
            running = true
            lastT = performance.now()
            raf = requestAnimationFrame( frame )
        }
        const stop = ( degrade ) => {
            running = false
            cancelAnimationFrame( raf )
            if( degrade ) { bg.querySelectorAll( '.fh-blob' ).forEach( ( b ) => { b.style.display = 'none' } ) }
        }

        window.addEventListener( 'pointermove', onMove, { passive: true } )
        document.addEventListener( 'visibilitychange', () => { if( document.hidden ) { stop( false ) } } )
    }

    if( 'requestIdleCallback' in window ) { requestIdleCallback( boot ) }
    else { setTimeout( boot, 200 ) }
</script>
