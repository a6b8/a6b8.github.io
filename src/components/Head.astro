---
// Head override — (Memo 015, Kap 6). Minimal extension of Starlight's default
// Head: keeps every default head element (favicons, meta, theme handling) intact
// via <Default> and only adds the Mermaid-Zoom wiring. The <script> (not
// is:inline) is bundled by Astro so the ES module import resolves.
import Default from '@astrojs/starlight/components/Head.astro'
---

<Default><slot /></Default>

<script>
    import { initMermaidZoom } from '../scripts/mermaid-zoom.mjs'
    initMermaidZoom()
</script>
