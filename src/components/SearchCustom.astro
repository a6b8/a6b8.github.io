---
// Search override — ports the 5 pagefind fixes from memo-init (Memo 015, Kap 5).
// 1. Section-tag injection on results (runtime half — build half in scripts/inject-pagefind-meta.mjs)
// 2. Permanent empty state with a curated (personal) suggestion list
// 3. Empty state mounts on the early/visible #starlight__search root
// 4. Mobile cancel + Escape close the dialog
// Bug 11 fix (05-memo-init-bugs finding #11): the MutationObserver in wire() was
// bound to BOTH DOMContentLoaded AND astro:page-load with no guard and no
// disconnect — two full-body-subtree observers ran for the whole session. A
// module-level `wired` flag now ensures exactly one observer is ever created.
import Default from '@astrojs/starlight/components/Search.astro'
---

<Default />

<script is:inline>
    ( function() {
        let pagefindLib = null
        const loadLib = async () => {
            if( pagefindLib ) { return pagefindLib }
            try {
                pagefindLib = await import( '/pagefind/pagefind.js' )
                await pagefindLib.options( {} )
                return pagefindLib
            } catch( e ) { return null }
        }

        const sectionByUrl = {}

        const insertTag = ( result, sectionText ) => {
            if( result.dataset.sectionInjected === 'true' ) { return }
            const titleInner = result.querySelector( '.pagefind-ui__result-inner > .pagefind-ui__result-title' )
            const target = titleInner || result.querySelector( '.pagefind-ui__result-title' )
            if( !target ) { return }
            const tag = document.createElement( 'div' )
            tag.className = 'pagefind-section-tag'
            tag.textContent = sectionText
            target.parentElement.insertBefore( tag, target )
            result.dataset.sectionInjected = 'true'
        }

        const resolveSection = async ( href ) => {
            if( sectionByUrl[ href ] !== undefined ) { return sectionByUrl[ href ] }
            const lib = await loadLib()
            if( !lib ) { sectionByUrl[ href ] = null; return null }
            try {
                const search = await lib.search( href.split( '/' ).filter( Boolean ).slice( -1 )[ 0 ] || '' )
                const datas = await Promise.all( search.results.map( ( r ) => r.data() ) )
                const found = datas.find( ( d ) => d.url === href || d.url + '/' === href || d.url === href + '/' )
                if( found && found.meta && found.meta.section ) {
                    sectionByUrl[ href ] = found.meta.section
                    return sectionByUrl[ href ]
                }
            } catch( e ) {}
            sectionByUrl[ href ] = null
            return null
        }

        const processResults = async () => {
            const results = document.querySelectorAll( '.pagefind-ui__result' )
            await Promise.all( Array.from( results ).map( async ( result ) => {
                if( result.dataset.sectionInjected === 'true' ) { return }
                const link = result.querySelector( '.pagefind-ui__result-link' )
                if( !link ) { return }
                const href = link.getAttribute( 'href' )
                if( !href ) { return }
                const section = await resolveSection( href )
                if( section ) { insertTag( result, section ) }
            } ) )
        }

        // -------- Fix 2: filled empty state (curated, personal) --------
        const SUGGESTIONS = {
            en: {
                heading: 'Suggested pages',
                items: [
                    { href: '/docs/overview/', label: 'Docs Overview' },
                    { href: '/docs/getting-started/', label: 'Getting Started' },
                    { href: '/specification/overview/', label: 'Specification Overview' },
                    { href: '/specification/formatting/', label: 'Formatting' },
                    { href: '/specification/class-architecture/', label: 'Class Architecture' },
                    { href: '/blog/', label: 'Blog' }
                ]
            }
        }

        const buildEmptyState = ( emptyMsg ) => {
            if( emptyMsg.dataset.suggestionsBuilt === 'true' ) { return }
            const data = SUGGESTIONS.en
            const heading = document.createElement( 'div' )
            heading.className = 'search-empty-state__heading'
            heading.textContent = data.heading
            const list = document.createElement( 'ul' )
            list.className = 'search-empty-state__list'
            data.items.forEach( ( item ) => {
                const li = document.createElement( 'li' )
                const link = document.createElement( 'a' )
                link.href = item.href
                link.textContent = item.label
                link.className = 'search-empty-state__link'
                li.appendChild( link )
                list.appendChild( li )
            } )
            emptyMsg.textContent = ''
            emptyMsg.appendChild( heading )
            emptyMsg.appendChild( list )
            emptyMsg.dataset.suggestionsBuilt = 'true'
        }

        const ensureEmptyState = () => {
            const drawer = document.querySelector( '.pagefind-ui' )
            if( !drawer ) { return }
            const root = document.querySelector( '#starlight__search' ) || drawer
            const input = drawer.querySelector( '.pagefind-ui__search-input' )
            const results = drawer.querySelector( '.pagefind-ui__results' )
            const hasQuery = input && input.value && input.value.trim().length > 0
            let emptyMsg = root.querySelector( '.search-empty-state' )

            if( !hasQuery ) {
                if( !emptyMsg ) {
                    emptyMsg = document.createElement( 'div' )
                    emptyMsg.className = 'search-empty-state'
                    emptyMsg.setAttribute( 'role', 'status' )
                    root.appendChild( emptyMsg )
                }
                buildEmptyState( emptyMsg )
                emptyMsg.style.display = ''
                if( results ) { results.style.minHeight = '120px' }
            } else if( emptyMsg ) {
                emptyMsg.style.display = 'none'
            }
        }

        // -------- Fix 4: mobile cancel button --------
        const wireMobileCancel = () => {
            const dialog = document.querySelector( 'dialog[data-starlight-search]' ) || document.querySelector( '.starlight-search-dialog' ) || document.querySelector( 'site-search dialog' )
            const clearBtn = document.querySelector( '.pagefind-ui__search-clear' )
            const closeAll = () => {
                if( dialog && typeof dialog.close === 'function' ) { dialog.close() }
                document.body.removeAttribute( 'data-mobile-menu-expanded' )
            }
            const cancelMobile = document.querySelector( '.starlight-search-cancel, [data-search-cancel], button[data-close-modal]' )
            if( cancelMobile && !cancelMobile.dataset.pbWired ) {
                cancelMobile.dataset.pbWired = 'true'
                cancelMobile.addEventListener( 'click', closeAll )
            }
            if( clearBtn && !clearBtn.dataset.pbWired ) {
                clearBtn.dataset.pbWired = 'true'
                clearBtn.addEventListener( 'click', () => {
                    setTimeout( ensureEmptyState, 0 )
                } )
            }
        }

        // Fix 4: Escape closes the search dialog from anywhere (idempotent).
        const wireEscape = () => {
            if( document.body.dataset.searchEscWired === 'true' ) { return }
            document.body.dataset.searchEscWired = 'true'
            document.addEventListener( 'keydown', ( event ) => {
                if( event.key !== 'Escape' ) { return }
                const dialog = document.querySelector( 'dialog[data-starlight-search]' ) || document.querySelector( '.starlight-search-dialog' ) || document.querySelector( 'site-search dialog' )
                if( dialog && dialog.open && typeof dialog.close === 'function' ) { dialog.close() }
                document.body.removeAttribute( 'data-mobile-menu-expanded' )
            } )
        }

        let scheduled = false
        const schedule = () => {
            if( scheduled ) { return }
            scheduled = true
            setTimeout( () => {
                scheduled = false
                processResults()
                ensureEmptyState()
                wireMobileCancel()
                wireEscape()
            }, 80 )
        }

        // Bug 11 fix: single observer for the whole session (guarded).
        let wired = false
        const wire = () => {
            if( wired ) { return }
            wired = true
            const observer = new MutationObserver( () => schedule() )
            observer.observe( document.body, { childList: true, subtree: true } )
            schedule()
        }

        document.addEventListener( 'DOMContentLoaded', wire )
        document.addEventListener( 'astro:page-load', wire )
    } )()
</script>

<script>
    // Search keyboard navigation (↑/↓/Enter/"/"/Escape, aria-activedescendant).
    // ES module import (not is:inline) so Astro bundles search-keyboard.mjs.
    import { init } from '../scripts/search-keyboard.mjs'
    init()
</script>

<style is:global>
    /* One hover area per result item */
    .pagefind-ui__result {
        cursor: pointer;
        transition: background-color 0.15s ease;
    }
    .pagefind-ui__result:hover,
    .pagefind-ui__result:focus-within {
        background-color: var(--sidebar-active-bg, rgba(245, 183, 77, 0.10));
    }
    .pagefind-ui__result .pagefind-ui__result-title:hover,
    .pagefind-ui__result .pagefind-ui__result-link:hover,
    .pagefind-ui__result .pagefind-ui__result-excerpt:hover {
        background-color: transparent;
    }

    /* Result highlighting for the search term */
    .pagefind-ui__result mark,
    .pagefind-ui__result .pagefind-ui__result-excerpt mark {
        background-color: var(--accent, #f5b74d);
        color: var(--bg-canvas, #0d1117);
        padding: 0 0.15em;
        border-radius: 3px;
        font-weight: 600;
    }

    /* Fix 2: filled empty state with suggestion list */
    .search-empty-state {
        padding: 1rem 0.75rem 1.25rem;
    }
    .search-empty-state__heading {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-inactive, #8b949e);
        padding: 0 0.5rem 0.5rem;
    }
    .search-empty-state__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .search-empty-state__link {
        display: block;
        padding: 0.5rem 0.6rem;
        border-radius: 6px;
        color: var(--text-primary, #f0f6fc);
        text-decoration: none;
        font-size: 14px;
        transition: background-color 0.12s ease;
    }
    .search-empty-state__link:hover,
    .search-empty-state__link:focus-visible {
        background-color: var(--sidebar-active-bg, rgba(245, 183, 77, 0.10));
        color: var(--accent, #f5b74d);
        outline: none;
    }

    .search-empty-state__link.is-active {
        background-color: var(--sidebar-active-bg, rgba(245, 183, 77, 0.14));
        color: var(--accent, #f5b74d);
        outline: 2px solid var(--accent, #f5b74d);
        outline-offset: -2px;
    }

    /* Keyboard-navigated result highlight */
    .pagefind-ui__result.is-active {
        position: relative;
        background-color: var(--sidebar-active-bg, rgba(245, 183, 77, 0.14));
    }
    .pagefind-ui__result.is-active::after {
        content: '';
        position: absolute;
        inset: 0;
        border: 2px solid var(--accent, #f5b74d);
        border-radius: 6px;
        pointer-events: none;
        z-index: 3;
    }

    .pagefind-ui__results {
        min-height: 80px;
    }

    /* Fix 4: mobile cancel button visible + clickable */
    @media (max-width: 800px) {
        .starlight-search-cancel,
        [data-search-cancel] {
            display: inline-flex !important;
            align-items: center;
            padding: 0.5rem 0.75rem;
            cursor: pointer;
            min-height: 44px;
        }
    }
</style>
